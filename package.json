{
  "name": "@anitshrsth/ui",
  "version": "0.2.0",
  "description": "A React component library for building data-rich UIs",
  "homepage": "https://github.com/priosshrsth/outside-ui#readme",
  "bugs": {
    "url": "https://github.com/priosshrsth/outside-ui/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priosshrsth/outside-ui.git"
  },
  "files": [
    "dist",
    "styles"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.mts",
      "default": "./dist/accordion/index.mjs"
    },
    "./button": {
      "types": "./dist/button/index.d.mts",
      "default": "./dist/button/index.mjs"
    },
    "./checkbox-group": {
      "types": "./dist/checkbox-group/index.d.mts",
      "default": "./dist/checkbox-group/index.mjs"
    },
    "./combobox": {
      "types": "./dist/combobox/index.d.mts",
      "default": "./dist/combobox/index.mjs"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.mts",
      "default": "./dist/dialog/index.mjs"
    },
    "./lazy-search": {
      "types": "./dist/lazy-search/index.d.mts",
      "default": "./dist/lazy-search/index.mjs"
    },
    "./radio-group": {
      "types": "./dist/radio-group/index.d.mts",
      "default": "./dist/radio-group/index.mjs"
    },
    "./search-query": {
      "types": "./dist/search-query/index.d.mts",
      "default": "./dist/search-query/index.mjs"
    },
    "./select": {
      "types": "./dist/select/index.d.mts",
      "default": "./dist/select/index.mjs"
    },
    "./table": {
      "types": "./dist/table/index.d.mts",
      "default": "./dist/table/index.mjs"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.mts",
      "default": "./dist/tabs/index.mjs"
    },
    "./toggle-group": {
      "types": "./dist/toggle-group/index.d.mts",
      "default": "./dist/toggle-group/index.mjs"
    },
    "./use-deferred-change": {
      "types": "./dist/use-deferred-change/index.d.mts",
      "default": "./dist/use-deferred-change/index.mjs"
    },
    "./package.json": "./package.json",
    "./styles/accordion.css": "./styles/accordion.css",
    "./styles/base.css": "./styles/base.css",
    "./styles/button.css": "./styles/button.css",
    "./styles/checkbox-group.css": "./styles/checkbox-group.css",
    "./styles/combobox.css": "./styles/combobox.css",
    "./styles/dialog.css": "./styles/dialog.css",
    "./styles.css": "./styles/index.css",
    "./styles/pagination.css": "./styles/pagination.css",
    "./styles/radio-group.css": "./styles/radio-group.css",
    "./styles/select.css": "./styles/select.css",
    "./styles/table.css": "./styles/table.css",
    "./styles/tabs.css": "./styles/tabs.css",
    "./styles/toggle-group.css": "./styles/toggle-group.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "storybook dev -p 6006",
    "dev:lib": "vp pack --watch",
    "test": "vp test",
    "tsc": "tsgo --noEmit",
    "check": "vp check && bun run tsc",
    "storybook:build": "storybook build",
    "release": "bumpp --commit --push --tag",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260416.2",
    "@vitest/browser-playwright": "^4.1.4",
    "bumpp": "^11.0.1",
    "clsx": "^2.1.1",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.18",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "react": ">=19",
    "react-dom": ">=19",
    "typescript": ">=6"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-virtual": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "bun@1.3.12",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
