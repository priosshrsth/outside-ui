{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["es2023", "dom", "dom.iterable"],
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    // `vite/client` ships ambient declarations for CSS / SVG / image
    // side-effect imports. Loading it via `types` (rather than only
    // via our local globals.d.ts) means those declarations come from
    // node_modules and are always in the type graph — including when
    // the pre-commit hook type-checks a subset of staged files.
    "types": ["node", "vite/client"],

    "paths": {
      "src/*": ["./src/*"]
    },

    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "declaration": true,
    // `isolatedDeclarations` is enforced only on the shipped library
    // surface via tsconfig.src.json. Turning it off here keeps stories /
    // .storybook TypeScript clean (factory-inferred meta types can't be
    // annotated without writing out Storybook's internal generics).
    "isolatedDeclarations": false,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },

  "include": ["src", "stories", ".storybook", "globals.d.ts"],
  "exclude": ["node_modules", "dist"]
}
